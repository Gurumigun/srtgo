# Discord 봇 토큰
DISCORD_TOKEN=your_discord_bot_token_here

# AES-256 마스터 키 (64자리 hex = 32바이트)
# 생성: python -c "import secrets; print(secrets.token_hex(32))"
SRTGO_MASTER_KEY=your_64_char_hex_key_here

# SQLite DB 경로
SRTGO_DB_PATH=data/srtgo.db

# Discord 채널 설정
MAIN_CHANNEL_ID=0
CATEGORY_ID=0

# 슬롯 설정
MAX_SLOTS=4

# 대화 타임아웃 (초)
CONVERSATION_TIMEOUT=300

# ── 매크로 회피 설정 ──

# 기본 폴링 간격 (감마분포 파라미터)
# 평균 대기 ≈ SHAPE × SCALE + MIN (초)
POLL_INTERVAL_SHAPE=5.0
POLL_INTERVAL_SCALE=0.5
POLL_INTERVAL_MIN=1.5

# 미세 휴식: N회 요청마다 짧은 휴식
MICRO_BREAK_INTERVAL_MIN=15
MICRO_BREAK_INTERVAL_MAX=30
MICRO_BREAK_DURATION_MIN=10.0
MICRO_BREAK_DURATION_MAX=45.0

# 활동/휴식 사이클
# 약 1시간 검색 후 1~3시간 휴식, 반복
POLL_ACTIVE_MINUTES=60
POLL_ACTIVE_JITTER=0.15
POLL_REST_MINUTES_MIN=30
POLL_REST_MINUTES_MAX=90

# 전체 검색 제한 (0=무제한)
POLL_MAX_HOURS=0
POLL_MAX_CYCLES=0

# ── NordVPN + Gluetun 프록시 설정 ──
# Gluetun 컨테이너가 NordVPN 한국 서버에 연결 후 SOCKS5 프록시 제공
# SRT/KTX API 트래픽만 프록시 경유 (Discord 트래픽은 직접 연결)

# Gluetun 컨테이너용 NordVPN 서비스 자격증명
# (my.nordaccount.com → Services → NordVPN → Manual setup)
NORDVPN_USER=your_nordvpn_service_username
NORDVPN_PASS=your_nordvpn_service_password

# 봇 프록시 설정 (Gluetun SOCKS5)
PROXY_ENABLED=true
PROXY_USER=
PROXY_PASS=
PROXY_SERVERS=gluetun
PROXY_PORT=1080
PROXY_ROTATE=false

# Gluetun 제어 API (휴식 사이클마다 VPN 재연결하여 IP 변경)
GLUETUN_API_URL=http://gluetun:8000
